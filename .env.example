# ============================================================
# Bandobusth.AI — Environment Configuration
# Copy this to .env and fill in your values
# ============================================================

# Server
PORT=5000
NODE_ENV=production

# MongoDB
MONGO_URI=mongodb://localhost:27017/bandobusth_ai
# For MongoDB Atlas (cloud):
# MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/bandobusth_ai

# JWT
JWT_SECRET=change_this_to_a_strong_random_secret_min_32_chars

# CORS
CORS_ORIGIN=http://localhost:5000

# Google Maps — Replace with your real API key
# Get from: https://console.cloud.google.com/
# Enable: Maps JavaScript API, Drawing Library, Geometry Library
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY
